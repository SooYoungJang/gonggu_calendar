{
  "name": "@gonggu/shared",
  "version": "0.1.0",
  "private": true,
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js"
    },
    "./schemas": {
      "types": "./dist/src/schemas/index.d.ts",
      "import": "./dist/src/schemas/index.js",
      "require": "./dist/src/schemas/index.js"
    },
    "./schemas/*": {
      "types": "./dist/src/schemas/*.d.ts",
      "import": "./dist/src/schemas/*.js",
      "require": "./dist/src/schemas/*.js"
    },
    "./hooks": {
      "types": "./dist/src/hooks/index.d.ts",
      "import": "./dist/src/hooks/index.js",
      "require": "./dist/src/hooks/index.js"
    },
    "./hooks/*": {
      "types": "./dist/src/hooks/*.d.ts",
      "import": "./dist/src/hooks/*.js",
      "require": "./dist/src/hooks/*.js"
    },
    "./utils": {
      "types": "./dist/src/utils/index.d.ts",
      "import": "./dist/src/utils/index.js",
      "require": "./dist/src/utils/index.js"
    },
    "./utils/*": {
      "types": "./dist/src/utils/*.d.ts",
      "import": "./dist/src/utils/*.js",
      "require": "./dist/src/utils/*.js"
    },
    "./constants": {
      "types": "./dist/src/constants/index.d.ts",
      "import": "./dist/src/constants/index.js",
      "require": "./dist/src/constants/index.js"
    },
    "./constants/*": {
      "types": "./dist/src/constants/*.d.ts",
      "import": "./dist/src/constants/*.js",
      "require": "./dist/src/constants/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
