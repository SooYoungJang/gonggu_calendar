{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@gonggu/shared/*": ["packages/shared/src/*"],
      "@gonggu/api/*": ["apps/api/src/*"],
      "@gonggu/mobile/*": ["apps/mobile/src/*"],
      "@gonggu/web/*": ["apps/web/src/*"]
    },
    "types": ["node", "jest", "@testing-library/jest-native"]
  },
  "exclude": ["node_modules", "dist", "build", ".next", ".expo", "coverage"]
}